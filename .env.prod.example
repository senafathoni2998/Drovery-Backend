# Production deploy config — copy to `.env` next to docker-compose.prod.yml and fill in.
# (docker compose auto-loads `.env`.) See DEPLOY.md.

# The public domain. Caddy gets a Let's Encrypt cert for it automatically. Point its DNS
# A/AAAA record at the VPS first. The mobile app then uses https://<DOMAIN>/api/v1.
DOMAIN=drovery.example.com

# Postgres password (used by postgres + pgbouncer + the api/worker/migrate connection strings).
# Generate a strong one, e.g.: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong

# JWT signing secrets — the prod boot guard REJECTS weak/placeholder values, so make these
# long & random. Generate each: openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
JWT_REFRESH_SECRET=change-me-another-64-hex-chars

# OPTIONAL — only if you serve the admin console on a DIFFERENT host than the API (the default
# single-domain setup is same-origin, so leave this blank). Comma-separated origins.
CORS_ORIGINS=

# Image source. Leave as 'drovery' to BUILD on the VPS. To PULL pre-built images from Docker
# Hub, set this to your Docker Hub username (matches the publish workflows) + pick a TAG.
DOCKER_REGISTRY=drovery
TAG=latest
