# ==================== APP ====================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ==================== DATABASE ====================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drovery?schema=public
# Max connections in this instance's pg pool. With N replicas, keep N×max under
# Postgres max_connections — or point DATABASE_URL at PgBouncer (see docker-compose).
# DATABASE_POOL_MAX=10
# Optional READ REPLICA. When set, lag-tolerant heavy reads (lists, tracking polls,
# stats, admin reports) route here; ALL writes + read-after-write/CAS reads stay on
# the primary. Unset → reads use the primary (single-DB dev/test is unchanged). A
# replica blip falls back to the primary (no 5xx).
# DATABASE_REPLICA_URL=postgresql://postgres:postgres@replica-host:5432/drovery?schema=public
# Reader pool size (defaults to DATABASE_POOL_MAX). Tune down (e.g. 5) for the API,
# and front the replica with its own PgBouncer at scale.
# DATABASE_REPLICA_POOL_MAX=10

# ==================== JWT ====================
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ==================== REDIS (required — queue + cache + rate limiting) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
# Managed Redis (ElastiCache/Upstash/etc.) usually needs auth + TLS:
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=true

# ==================== WORKER ====================
# Role: unset/'all' = API also processes jobs (single process); 'api' = enqueue only
# PROCESS_ROLE=all
# Parallel jobs per worker
# SIM_WORKER_CONCURRENCY=10

# ==================== CORS ====================
# Comma-separated browser allowlist (enables credentials). Unset → wildcard, no credentials.
# CORS_ORIGINS=https://app.drovery.com,https://admin.drovery.com

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxx  (also set EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY in mobile)

# ==================== GEOCODING ====================
GEOCODING_PROVIDER=nominatim
# GOOGLE_MAPS_API_KEY=xxxx

# ==================== WEATHER (drone serviceability) ====================
# Unset → deterministic mock weather. Set to use real OpenWeather (fail-open).
# OPENWEATHER_API_KEY=xxxx

# ==================== LIVE DRONE TELEMETRY INGESTION ====================
# Shared key a drone-gateway sends as `x-ingest-key` to POST /ingest/telemetry.
# FAIL-CLOSED: unset → the ingest endpoint is disabled (every request denied).
# INGEST_API_KEY=change-me-to-a-random-ingest-key
# Optional second factor: when set, also require an `x-ingest-timestamp` + an
# `x-ingest-signature` = HMAC-SHA256 over `${timestamp}.${method}.${path}.${rawBody}`
# (anti-replay 5-min window + binds the request line, so a captured signature can't
# be retargeted to another route/drone/command). Unset → key-only auth.
# INGEST_HMAC_SECRET=change-me-to-a-random-hmac-secret
# Optional MQTT broker for real-IoT ingestion. Unset → MQTT subscriber is a
# logged no-op (the HTTP endpoint is the active transport; broker path deferred).
# MQTT_URL=mqtts://broker.example.com:8883

# ==================== STUCK-DELIVERY WATCHDOG (self-healing reaper) ====================
# Worker-tier repeatable scan that reaps LIVE in-flight deliveries whose telemetry
# has gone silent (lost-comms drone, or a return flight that died) → DELIVERY_FAILED
# + customer refund, so a stranded delivery never sits in-flight forever. SIMULATED
# deliveries are out of scope (the sim drives them). All four knobs have safe
# defaults; read at worker boot, so changes need a worker restart/redeploy.
# WATCHDOG_ENABLED=true            # kill-switch (default on); false → reaper paused + scheduler torn down on next boot
# WATCHDOG_SCAN_INTERVAL_MS=60000  # how often the reaper scans
# WATCHDOG_SILENCE_MS=600000       # THE safety knob: telemetry-silence window (10m ≫ ~5s position cadence) before a LIVE in-flight delivery is reaped. Widen during a degraded-telemetry incident.
# WATCHDOG_MIN_AGE_MS=600000       # never reap a delivery younger than this (defaults to WATCHDOG_SILENCE_MS) — guards a brand-new flight with no tracking row yet

# ==================== PARTITION MAINTENANCE (time-range partitioned tables) ====================
# Worker-tier repeatable sweep that keeps RANGE("createdAt")-partitioned tables (today:
# notifications) provisioned: drains the DEFAULT partition, creates the forward window of
# monthly children, and (opt-in) drops children past the retention window. See
# prisma/PARTITIONING.md.
# PARTITION_MAINTENANCE_ENABLED=true   # kill-switch (default on); false → paused + scheduler torn down on next boot
# PARTITION_SCAN_INTERVAL_MS=21600000  # sweep cadence (default 6h — partitions move by the month)
# PARTITION_MONTHS_AHEAD=3             # months of FUTURE child partitions kept ready (~90-day runway)
# PARTITION_RETAIN_MONTHS=0            # drop children older than N months; 0 (default) = retention disabled (keep all)

# ==================== MAIL / STORAGE (unset → dev fallbacks) ====================
# MAIL_PROVIDER=         # unset: emails are logged. set + integrate SendGrid/SES
# MAIL_FROM=no-reply@drovery.com
# STORAGE_PROVIDER=      # unset: proof photos stored inline as data URLs / placeholder

# ==================== PUSH NOTIFICATIONS ====================
EXPO_ACCESS_TOKEN=xxxx

# ==================== API DOCS (Swagger / OpenAPI) ====================
# Interactive docs at /api/v1/docs + machine-readable spec at /api/v1/docs-json
# (enumerates every route incl. /ingest/* and /admin/*; no secret VALUES). ON by
# default — this backend is a portfolio showcase, so the docs are intentionally
# published. Set to the exact string `false` to keep the surface unpublished in a
# locked-down deployment.
# SWAGGER_ENABLED=false

# ==================== METRICS (Prometheus) ====================
# METRICS_ENABLED=false   # kill switch (default: enabled)
# METRICS_PORT=9091       # worker's standalone /metrics HTTP server port

# ==================== TRACING (OpenTelemetry, distributed) ====================
# OFF by default (zero overhead). Enabled when TRACING_ENABLED is true OR an OTLP
# endpoint is set — AND SENTRY_DSN is UNSET (Sentry owns OTel when a DSN is present;
# pick one owner). A bad endpoint/instrumentation degrades to untraced, never crashes.
# TRACING_ENABLED=true
# Base OTLP/HTTP collector endpoint (Tempo/Jaeger/otelcol). Set the BASE URL — the
# exporter appends /v1/traces itself. Unset + TRACING_ENABLED → console exporter.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER=console   # force the console span exporter (local verification)
# Fraction of root traces sampled (0..1). Default: 0.05 in production, 1 in dev.
# OTEL_TRACES_SAMPLER_ARG=0.05

# ==================== LOAD TESTING (non-prod only) ====================
# Bypass rate limiting so a single-IP load test measures real throughput, not
# the limiter. Refused at boot when NODE_ENV=production.
# LOADTEST_BYPASS_THROTTLE=true

# ==================== ERROR TRACKING (unset → no-op) ====================
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
# SENTRY_RELEASE=drovery-backend@0.0.1
# SENTRY_TRACES_SAMPLE_RATE=0   # 0..1, fraction of transactions traced
