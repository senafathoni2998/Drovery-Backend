# EXAMPLE ONLY — never put real secrets in git. Overlays replace this:
#   - local: secrets.local.env (strong dev values, gitignored)
#   - prod:  an ExternalSecret / SealedSecret named drovery-secrets, created out of band
# Note: Kubernetes Secrets are base64, NOT encrypted at rest unless etcd
# encryption is enabled.
JWT_SECRET=replace_with_strong_random_min_24_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_min_24_chars
# App traffic -> PgBouncer (transaction pooling):
DATABASE_URL=postgresql://postgres:postgres@pgbouncer:5432/drovery?schema=public
# Migrations -> Postgres DIRECT (bypass the pooler for DDL/advisory locks):
DATABASE_URL_DIRECT=postgresql://postgres:postgres@postgres:5432/drovery?schema=public
REDIS_PASSWORD=
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
EXPO_ACCESS_TOKEN=xxxx
SENTRY_DSN=
